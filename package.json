    "eslint": "^9.31.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "prettier": "^3.6.2",
    "typescript": "^4.6.4",
    "typescript-eslint": "^8.36.0",
    "vite": "^7.0.7",
